// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------
// ENUMS
// ---------------------------------------------------------

enum ProfileEnum {
  P1 // Primaire, Collège, Lycée
  P2 // Lycée pro, BTS, Prépa, IUT
  P3 // Université, Grande École
  P4 // Centre de formation
}

enum PlanEnum {
  FREE
  BASIC
  PREMIUM
  ENTERPRISE
}

enum RoleEnum {
  super_admin
  admin
  director
  teacher
  secretary
  parent
  student
}

enum StatusEnum {
  active
  archived
}

enum PeriodTypeEnum {
  trimestre
  semestre
  sequence
  module
}

enum PeriodStatusEnum {
  ouvert
  cloture
}

enum EvalTypeEnum {
  devoir
  examen
  tp
  oral
  cc
}

enum FeeStatusEnum {
  non_paye
  partiel
  paye
}

enum DecisionEnum {
  admis
  ajourne
  admis_avec_dette
  exclu
}

// ---------------------------------------------------------
// MODELS
// ---------------------------------------------------------

model Tenant {
  id        String      @id @default(uuid())
  name      String
  profile   ProfileEnum
  plan      PlanEnum    @default(FREE)
  logoUrl   String?
  active    Boolean     @default(true)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  users       User[]
  students    Student[]
  schoolYears SchoolYear[]
  periods     Period[]
  classes     Class[]
  subjects    Subject[]
}

model User {
  id           String   @id @default(uuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id])
  nom          String
  prenom       String
  email        String   @unique
  telephone    String?
  role         RoleEnum
  statut       Boolean  @default(true)
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  teachers Teacher[]
}

model Student {
  id             String     @id @default(uuid())
  tenantId       String
  tenant         Tenant     @relation(fields: [tenantId], references: [id])
  schoolYearId   String
  schoolYear     SchoolYear @relation(fields: [schoolYearId], references: [id])
  classId        String
  class          Class      @relation(fields: [classId], references: [id])
  matricule      String?
  nom            String
  prenom         String
  sexe           String     // M, F
  dateNaissance  DateTime
  lieuNaissance  String?
  adresse        String?
  telephoneParent String?
  emailParent    String?
  statut         Boolean    @default(true)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  grades   Grade[]
  fees     Fee[]
  absences Absence[]
}

model Teacher {
  id         String   @id @default(uuid())
  tenantId   String
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  matricule  String?
  specialite String?
  statut     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  assignments TeacherAssignment[]
  grades      Grade[]
}

model SchoolYear {
  id        String     @id @default(uuid())
  tenantId  String
  tenant    Tenant     @relation(fields: [tenantId], references: [id])
  libelle   String
  dateDebut DateTime
  dateFin   DateTime
  statut    StatusEnum @default(active)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  periods     Period[]
  students    Student[]
  classes     Class[]
  assignments TeacherAssignment[]
}

model Period {
  id           String           @id @default(uuid())
  tenantId     String
  tenant       Tenant           @relation(fields: [tenantId], references: [id])
  schoolYearId String
  schoolYear   SchoolYear       @relation(fields: [schoolYearId], references: [id])
  libelle      String
  type         PeriodTypeEnum
  statut       PeriodStatusEnum @default(ouvert)
  dateDebut    DateTime
  dateFin      DateTime
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  grades Grade[]
}

model Class {
  id           String     @id @default(uuid())
  tenantId     String
  tenant       Tenant     @relation(fields: [tenantId], references: [id])
  schoolYearId String
  schoolYear   SchoolYear @relation(fields: [schoolYearId], references: [id])
  nom          String
  niveau       String
  parentClassId String?
  capacite     Int?
  statut       Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  students    Student[]
  assignments TeacherAssignment[]
}

model Subject {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  nom         String
  code        String?
  coefficient Decimal  @db.Decimal(4, 2)
  creditsEcts Int?
  statut      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  assignments TeacherAssignment[]
  grades      Grade[]
}

model TeacherAssignment {
  id           String     @id @default(uuid())
  tenantId     String
  teacherId    String
  teacher      Teacher    @relation(fields: [teacherId], references: [id])
  classId      String
  class        Class      @relation(fields: [classId], references: [id])
  subjectId    String
  subject      Subject    @relation(fields: [subjectId], references: [id])
  schoolYearId String
  schoolYear   SchoolYear @relation(fields: [schoolYearId], references: [id])
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([tenantId, teacherId, classId, subjectId, schoolYearId])
}

model Grade {
  id             String       @id @default(uuid())
  tenantId       String
  schoolYearId   String
  periodId       String
  period         Period       @relation(fields: [periodId], references: [id])
  classId        String
  subjectId      String
  subject        Subject      @relation(fields: [subjectId], references: [id])
  studentId      String
  student        Student      @relation(fields: [studentId], references: [id])
  teacherId      String
  teacher        Teacher      @relation(fields: [teacherId], references: [id])
  valeur         Decimal      @db.Decimal(5, 2)
  valeurMax      Decimal      @default(20) @db.Decimal(5, 2)
  typeEvaluation EvalTypeEnum
  ponderation    Decimal      @default(1) @db.Decimal(4, 2)
  dateSaisie     DateTime     @default(now())
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([tenantId, studentId, subjectId, periodId, typeEvaluation])
}

model Absence {
  id        String   @id @default(uuid())
  tenantId  String
  studentId String
  student   Student  @relation(fields: [studentId], references: [id])
  classId   String
  subjectId String?
  date      DateTime
  statut    String   // absent, retard, justifie
  motif     String?
  createdAt DateTime @default(now())
}

model Fee {
  id           String        @id @default(uuid())
  tenantId     String
  studentId    String
  student      Student       @relation(fields: [studentId], references: [id])
  schoolYearId String
  libelle      String
  montant      Decimal       @db.Decimal(10, 2)
  montantPaye  Decimal       @default(0) @db.Decimal(10, 2)
  statut       FeeStatusEnum @default(non_paye)
  dateEcheance DateTime
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}
